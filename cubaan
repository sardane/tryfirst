<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>easy vibe · interactive card</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(145deg, #f9f3e6 0%, #ffe6d5 100%);
      font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, 'Inter', 'Helvetica Neue', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    /* main card — clean, soft, modern */
    .easy-card {
      max-width: 620px;
      width: 100%;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(2px);
      border-radius: 3rem;
      box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.25), 0 8px 18px rgba(0, 0, 0, 0.05);
      padding: 2rem 2rem 2.5rem;
      transition: transform 0.2s ease;
      border: 1px solid rgba(255, 245, 235, 0.7);
      text-align: center;
    }

    .easy-card:hover {
      transform: scale(1.01);
    }

    /* header decoration */
    .badge {
      display: inline-block;
      background: #fde3cf;
      color: #b45f2b;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 1px;
      padding: 0.3rem 1rem;
      border-radius: 40px;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      backdrop-filter: blur(4px);
    }

    h1 {
      font-size: 2.8rem;
      font-weight: 700;
      color: #2d2a24;
      letter-spacing: -0.3px;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    h1 span {
      background: #fff0e4;
      padding: 0 0.2rem;
      border-radius: 60px;
      display: inline-block;
    }

    .sub {
      font-size: 1.1rem;
      color: #6c5a4b;
      margin-bottom: 2rem;
      border-bottom: 2px dotted #f8cfb0;
      display: inline-block;
      padding-bottom: 4px;
    }

    /* interactive counter panel */
    .counter-panel {
      background: #ffffffcc;
      backdrop-filter: blur(8px);
      border-radius: 2.5rem;
      padding: 1.8rem 1rem;
      margin: 1.5rem 0 1rem;
      box-shadow: inset 0 1px 2px #ffffff80, 0 8px 20px rgba(0, 0, 0, 0.05);
    }

    .counter-number {
      font-size: 5.5rem;
      font-weight: 800;
      color: #c26e3c;
      background: linear-gradient(135deg, #b45f2b, #e6965c);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      text-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
      line-height: 1;
      margin-bottom: 0.8rem;
      letter-spacing: 4px;
    }

    .counter-label {
      font-size: 1rem;
      font-weight: 500;
      color: #7f6856;
      background: #fff3ea;
      display: inline-block;
      padding: 0.2rem 1.2rem;
      border-radius: 60px;
    }

    .button-group {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin: 2rem 0 1rem;
    }

    .btn {
      border: none;
      background: white;
      font-size: 1.2rem;
      font-weight: 600;
      padding: 0.7rem 1.6rem;
      border-radius: 3rem;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: inherit;
    }

    .btn-primary {
      background: #f5bc8e;
      color: #4a2c18;
      border: 1px solid #ffe1ca;
    }

    .btn-primary:hover {
      background: #f0ab77;
      transform: translateY(-3px);
      box-shadow: 0 10px 20px -5px rgba(193, 109, 50, 0.4);
    }

    .btn-secondary {
      background: #e9dfd7;
      color: #6b4c34;
      border: 1px solid #f7ede5;
    }

    .btn-secondary:hover {
      background: #dfcfc2;
      transform: translateY(-2px);
    }

    .btn-reset {
      background: #ffffff;
      color: #b45a2e;
      border: 1px solid #f5cfb3;
    }

    .btn-reset:hover {
      background: #fff3ec;
      transform: scale(0.97);
    }

    /* fun quote section */
    .quote-box {
      margin-top: 2rem;
      padding: 1rem 1rem;
      background: #fef8f2;
      border-radius: 2rem;
      font-size: 0.95rem;
      font-style: italic;
      color: #a06e48;
      border-left: 5px solid #f5bc8e;
      text-align: center;
      transition: all 0.2s;
    }

    .quote-text {
      font-weight: 500;
    }

    .refresh-quote {
      background: none;
      border: none;
      font-size: 0.75rem;
      color: #b68662;
      cursor: pointer;
      margin-top: 8px;
      text-decoration: underline;
      opacity: 0.7;
      transition: 0.2s;
    }

    .refresh-quote:hover {
      opacity: 1;
      color: #c26e3c;
    }

    /* footer tiny */
    .footer-note {
      margin-top: 2rem;
      font-size: 0.7rem;
      color: #bb9a7c;
      border-top: 1px solid #ffe1cf;
      padding-top: 1rem;
      display: flex;
      justify-content: center;
      gap: 1rem;
    }

    /* responsive touches */
    @media (max-width: 500px) {
      .easy-card {
        padding: 1.5rem;
      }
      h1 {
        font-size: 2rem;
      }
      .counter-number {
        font-size: 4rem;
      }
      .btn {
        padding: 0.5rem 1.2rem;
        font-size: 1rem;
      }
      .button-group {
        gap: 0.7rem;
      }
    }

    /* simple accessibility */
    button:active {
      transform: scale(0.96);
    }
  </style>
</head>
<body>

<div class="easy-card">
  <div class="badge">✨ just easy things ✨</div>
  <h1>
    <span>🌻</span> easy clicker <span>🍃</span>
  </h1>
  <div class="sub">simple, smooth, & joyful</div>

  <!-- interactive counter module -->
  <div class="counter-panel">
    <div class="counter-number" id="counterValue">0</div>
    <div class="counter-label">times you clicked 💫</div>

    <div class="button-group">
      <button class="btn btn-primary" id="incrementBtn" aria-label="increase">+ 1  ➕</button>
      <button class="btn btn-secondary" id="decrementBtn" aria-label="decrease">- 1  ➖</button>
      <button class="btn btn-reset" id="resetBtn" aria-label="reset">⟳ reset</button>
    </div>
  </div>

  <!-- inspirational / fun quote section (dynamic) -->
  <div class="quote-box" id="quoteBox">
    <div class="quote-text" id="quoteText">“Keep it simple, make it count.”</div>
    <button class="refresh-quote" id="newQuoteBtn">↺ new vibe</button>
  </div>

  <div class="footer-note">
    <span>⚡ easy peasy</span>
    <span>🍰 just for fun</span>
  </div>
</div>

<script>
  // --------------------------------------------------------------
  // EASY AND CLEAN: counter logic + dynamic motivational quotes
  // --------------------------------------------------------------

  // ---- COUNTER ELEMENTS ----
  const counterDisplay = document.getElementById('counterValue');
  const incrementBtn = document.getElementById('incrementBtn');
  const decrementBtn = document.getElementById('decrementBtn');
  const resetBtn = document.getElementById('resetBtn');

  // ---- QUOTE ELEMENTS ----
  const quoteTextEl = document.getElementById('quoteText');
  const newQuoteBtn = document.getElementById('newQuoteBtn');

  // ---- counter state (simple) ----
  let count = 0;

  // helper: update DOM with current count + small animation effect (optional but friendly)
  function updateCounterDisplay() {
    counterDisplay.innerText = count;
    // tiny playful bounce effect on the number (just for extra easy joy)
    counterDisplay.style.transform = 'scale(1.08)';
    setTimeout(() => {
      if (counterDisplay) counterDisplay.style.transform = 'scale(1)';
    }, 120);
    // also optional: change background briefly? but we keep minimal
  }

  // core actions
  function increment() {
    count++;
    updateCounterDisplay();
  }

  function decrement() {
    count--;
    updateCounterDisplay();
  }

  function resetCounter() {
    count = 0;
    updateCounterDisplay();
  }

  // attach event listeners with safety (clean)
  incrementBtn.addEventListener('click', increment);
  decrementBtn.addEventListener('click', decrement);
  resetBtn.addEventListener('click', resetCounter);

  // ---------- QUOTE DATABASE (easy & cheerful) ----------
  const quotesList = [
    "“Simplicity is the ultimate sophistication.” — da Vinci ✨",
    "“Easy does it, but do it anyway.” 🌈",
    "“Small steps, big joy.” 🐾",
    "“You are doing amazing, sweetie.” 🍭",
    "“Make it easy on yourself.” 🎈",
    "“Breathe. Click. Smile.” 😊",
    "“Progress, not perfection.” 🌱",
    "“This code? pure easy magic.” 🪄",
    "“Every click adds a little happy.” 🍀",
    "“Stay curious, stay playful.” 🧸",
    "“You've got this ✨ one click at a time.”",
    "“No pressure, just good vibes.” 🌊"
  ];

  // function to update quote randomly
  function setRandomQuote() {
    const randomIndex = Math.floor(Math.random() * quotesList.length);
    const newQuote = quotesList[randomIndex];
    quoteTextEl.innerText = newQuote;
    // optional small fade animation
    quoteTextEl.style.opacity = '0';
    setTimeout(() => {
      quoteTextEl.style.opacity = '1';
    }, 50);
  }

  // also provide a second method that cycles without repetition? but random is perfectly easy
  // initial quote on load (could be first or random)
  function initRandomQuote() {
    const randomStart = Math.floor(Math.random() * quotesList.length);
    quoteTextEl.innerText = quotesList[randomStart];
  }

  // event for new quote button
  newQuoteBtn.addEventListener('click', setRandomQuote);

  // bonus: animate card on certain counter milestones? just a little extra "easy win"
  // When counter reaches multiples of 5, show small celebration in quote (without breaking)
  // but we'll add a little surprise: if count is multiple of 5 and count > 0 -> special temporary message
  // we only modify inside increment/decrement/reset and show a temporary hint, but keep it playful.

  let celebrationTimeout = null;

  function showMilestoneMessage(message) {
    // store original quote so we don't lose it permanently
    const originalQuote = quoteTextEl.innerText;
    quoteTextEl.innerText = message;
    if (celebrationTimeout) clearTimeout(celebrationTimeout);
    celebrationTimeout = setTimeout(() => {
      // restore previous quote only if it hasn't been changed by user meanwhile?
      // but to be safe: if current quote still equals the celebration message, restore original stored quote
      if (quoteTextEl.innerText === message) {
        quoteTextEl.innerText = originalQuote;
      } else {
        // if user changed quote during celebration, no worries, keep their choice
      }
    }, 1800);
  }

  // enhance counter actions: milestone detection & cool feedback
  function enhancedIncrement() {
    increment();
    if (count !== 0 && count % 5 === 0 && count > 0) {
      showMilestoneMessage(`🎉 WOW! ${count} clicks — you're on fire! 🔥`);
    } else if (count === 1) {
      showMilestoneMessage(`⭐ first click! welcome aboard ⭐`);
    } else if (count === 10) {
      showMilestoneMessage(`🍰 TEN points! you're a star 🍰`);
    } else if (count === 20) {
      showMilestoneMessage(`🏆 legend mode: ${count} clicks! 🏆`);
    } else if (count === 42) {
      showMilestoneMessage(`🪐 answer to everything? ${count} clicks! 🪐`);
    }
  }

  function enhancedDecrement() {
    decrement();
    if (count < 0) {
      showMilestoneMessage(`🌙 exploring negative vibes... click up! ☀️`);
    } else if (count === 0) {
      showMilestoneMessage(`✨ back to zero — fresh start ✨`);
    } else if (count % 5 === 0 && count !== 0 && count > 0) {
      showMilestoneMessage(`🌟 still groovy at ${count} clicks 🌟`);
    }
  }

  function enhancedReset() {
    resetCounter();
    showMilestoneMessage(`⟳ reset to zero. clean slate. let's go! 🧼`);
    // optional: also refresh quote for a fresh feel? but keep gentle
    // we can give a small fresh vibe but not overwrite user quote if they like it
    // I'll just show message
  }

  // replace event listeners with enhanced versions
  // remove previous listeners and attach new ones (to avoid double triggers)
  // But it's safe: remove old then add new
  incrementBtn.removeEventListener('click', increment);
  decrementBtn.removeEventListener('click', decrement);
  resetBtn.removeEventListener('click', resetCounter);

  incrementBtn.addEventListener('click', enhancedIncrement);
  decrementBtn.addEventListener('click', enhancedDecrement);
  resetBtn.addEventListener('click', enhancedReset);

  // also if user resets and double click edge? fine

  // initialize counter display with zero
  updateCounterDisplay();

  // initialize first random quote
  initRandomQuote();

  // one more small interactive: keyboard support for easy access? (bonus but easy)
  // left/right keys for increment/decrement and R for reset
  window.addEventListener('keydown', (e) => {
    // prevent accidental page scrolling with arrow keys while focused on card
    if (e.key === 'ArrowUp' || e.key === 'ArrowRight' || e.key === '+' || e.key === '=') {
      e.preventDefault();
      enhancedIncrement();
    } else if (e.key === 'ArrowDown' || e.key === 'ArrowLeft' || e.key === '-') {
      e.preventDefault();
      enhancedDecrement();
    } else if (e.key === 'r' || e.key === 'R') {
      e.preventDefault();
      enhancedReset();
    } else if (e.key === 'q' || e.key === 'Q') {
      e.preventDefault();
      setRandomQuote();
    }
  });

  // optional tooltip instruction (add tiny subtle hint in footer)
  const footerNote = document.querySelector('.footer-note');
  if (footerNote && !document.querySelector('.key-hint')) {
    const hintSpan = document.createElement('span');
    hintSpan.className = 'key-hint';
    hintSpan.style.fontSize = '0.65rem';
    hintSpan.style.opacity = '0.7';
    hintSpan.innerHTML = '⌨️ ↑/↓  •  R reset  •  Q quote';
    footerNote.appendChild(hintSpan);
  }

  // also ensure that negative numbers look fine, but backgroundclip text works great
  // add a tiny last detail: update title on counter change? fun but optional.
  function updateDocumentTitle() {
    let titleCount = count;
    if (titleCount !== 0) {
      document.title = `(${titleCount}) · easy clicker`;
    } else {
      document.title = `easy clicker · happy clicks`;
    }
  }
  // Override updateCounterDisplay to include title
  const originalUpdate = updateCounterDisplay;
  window.updateCounterDisplay = function() {
    originalUpdate();
    updateDocumentTitle();
  };
  // replace with custom but careful
  updateCounterDisplay = function() {
    counterDisplay.innerText = count;
    counterDisplay.style.transform = 'scale(1.08)';
    setTimeout(() => {
      if (counterDisplay) counterDisplay.style.transform = 'scale(1)';
    }, 120);
    updateDocumentTitle();
  };
  // rebind the function references for internal use
  // re-run initial display & keep consistent
  // reassign to ensure future calls use title update
  window.updateCounterDisplay = updateCounterDisplay;
  // re-sync current count display with proper title
  updateCounterDisplay();

  // optional: small effect for quote changes: rippling color? but simple is perfect.
  // final safe: ensure that decrement/increment/reset use current count and update title properly
  // They already call updateCounterDisplay() - it's bound to our new version.
  // Fix: re-declare functions to use the new updateCounterDisplay
  // overwrite count modifiers to ensure they use the updated display function
  // Everything fine! but double-check: enhanced functions call increment() which used original updateCounterDisplay?
  // No, we replaced the global updateCounterDisplay function, so it's consistent.

  // ensure that the counter display functions use the same scope.
  // just to be safe: rebind increment count because original increment used old updateCounterDisplay? 
  // Actually increment() calls updateCounterDisplay() which now is the new version (due to hoisting).
  // but we defined updateCounterDisplay as function expression and later replaced it.
  // increment() is closure referencing the updateCounterDisplay symbol, which is now overridden.
  // yes it works.

  // Minor edge: we also override 'updateCounterDisplay' var, and that's perfect.
  // Now also ensure milestone detection uses current count display.
  console.log('✅ easy mode — ready to spread good vibes');
</script>
</body>
</html>
